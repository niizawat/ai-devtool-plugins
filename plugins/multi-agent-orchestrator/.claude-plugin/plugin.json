{
  "name": "multi-agent-orchestrator",
  "version": "0.1.0",
  "description": "計画 → 並列実装 → 統合 → QA ループを回すための開発プラグイン。Main Planner がタスクを分割し、領域 Worker（frontend / backend / mobile / infra）が並列実装、Integrator が統合、QA が品質ゲートで合否判定する開発フローを提供します。",
  "author": {
    "name": "niizawat",
    "email": "niizawa.tadashi@classmethod.jp"
  },
  "license": "MIT",
  "agents": [
    "main-planner",
    "sub-planner",
    "integrator",
    "qa",
    "worker-frontend",
    "worker-backend",
    "worker-mobile",
    "worker-infra"
  ],
  "commands": [
    "ma-plan",
    "ma-parallel-agents",
    "ma-handoff",
    "ma-integrate",
    "ma-qa",
    "ma-qa-fail-to-fixplan",
    "ma-worktree-create",
    "ma-worktree-cleanup"
  ]
}
